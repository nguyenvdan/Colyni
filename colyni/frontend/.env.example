# Dev (Vite on :5173): leave unset — Vite proxies /api and /v1 (see vite.config.ts).

# When the built UI is served from colyni-cluster (:52415), the app auto-calls the Colyni API at
# http://<same-host>:8787 unless you override:
# VITE_COLYNI_LEDGER_URL=http://127.0.0.1:8787

# Legacy: full API origin for some production static hosts (rare).
# VITE_COLYNI_API_URL=https://api.yourdomain.com
