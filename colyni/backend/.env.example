# Copy to .env and adjust.

# OpenAI-compatible inference API (colyni-cluster default port)
INFERENCE_BASE_URL=http://127.0.0.1:52415

# SQLite database file (default: colyni.db next to main.py)
# COLYNI_DATABASE=./colyni.db

# Comma-separated origins for browser CORS (dev + cluster UI on :52415 + LAN)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:52415,http://127.0.0.1:52415
